# pedalbot — copie para .env e preencha. NUNCA commite o .env.

# ── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=            # do @BotFather
TELEGRAM_ALLOWED_USERS=        # CSV de IDs numéricos (OBRIGATÓRIO — sem isto o bot não sobe)
TELEGRAM_WEBHOOK_SECRET=       # 32 bytes aleatórios; usado no setWebhook (só Cloud Run)

# ── Backends (o bot é cliente HTTP de ambos) ──────────────────────────────
SABIA_BASE_URL=http://localhost:8080
SABIA_APP_PASSWORD=            # HTTP Basic do sabiá (vazio = sem gate)
AMORA_BASE_URL=https://amora.pedalhidrografi.co

# ── GCP / Cloud Run (modo primário) ───────────────────────────────────────
GCP_PROJECT=pedal-hidrografico
GCP_REGION=southamerica-east1
CLOUD_TASKS_QUEUE=phbot-jobs
WORKER_URL=                    # URL do serviço ph-bot-worker (o webhook enfileira p/ cá)
WORKER_SA_EMAIL=              # service account com role p/ o OIDC Tasks→worker
FIRESTORE_PREFIX=phbot_
